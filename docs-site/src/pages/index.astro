			.senpai-card-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.85rem; }
			.senpai-orb { display: inline-flex; }
			.senpai-orb img { width: 34px; height: 34px; animation: senpai-breathe 4s ease-in-out infinite; }
			@keyframes senpai-breathe { 0%,100% { transform: scale(1); } 50% { transform: scale(1.06); } }
			.senpai-name { font-weight: 680; }
			.senpai-mode { margin-left: auto; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--cyan);
				background: rgba(111,214,240,0.08); border: 1px solid rgba(111,214,240,0.25); padding: 0.2rem 0.55rem; border-radius: 999px; }
			.senpai-line { margin: 0 0 0.9rem; font-size: 1.05rem; line-height: 1.5; min-height: 3.15em; color: var(--text); }
			.senpai-line.is-typing::after { content: '▍'; color: var(--cyan); animation: caret 1s step-end infinite; }
			@keyframes caret { 50% { opacity: 0; } }
			.senpai-hint { font-size: 0.8rem; color: var(--muted); }
			.senpai-copy h3 { font-size: clamp(1.3rem, 2.6vw, 1.8rem); margin: 0.5rem 0 0.7rem; letter-spacing: -0.02em; }
			.senpai-copy p { margin: 0 0 1rem; color: var(--muted); }
			.text-link { font-weight: 600; }

			/* ── Download cards ── */
			.cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
			.card {
				background: var(--panel); border: 1px solid var(--panel-border); border-radius: var(--radius);
				padding: 1.6rem; backdrop-filter: blur(8px); transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
			}
			.card:hover { transform: translateY(-3px); border-color: rgba(111, 214, 240, 0.4); box-shadow: 0 12px 40px rgba(111, 214, 240, 0.1); }
			.card-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
			.card-head h3 { margin: 0; font-size: 1.4rem; }
			.arch { font-size: 0.8rem; color: var(--muted); }
			.card p { color: var(--muted); font-size: 0.95rem; }
			.card-btn {
				display: inline-block; margin-top: 0.4rem; padding: 0.5rem 1.1rem; border-radius: 10px;
				background: linear-gradient(135deg, var(--cyan), var(--peri)); color: #04121a; font-weight: 620;
			}
			.card-btn:hover { text-decoration: none; opacity: 0.92; }
			.card-more { display: inline-block; margin-top: 0.9rem; margin-left: 0.9rem; font-size: 0.9rem; }
			.cards-note { text-align: center; color: var(--muted); font-size: 0.9rem; max-width: 60ch; margin: 1.5rem auto 0; }

			/* ── Trust ── */
			.trust-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
			.trust-item { background: var(--panel); border: 1px solid var(--panel-border); border-radius: var(--radius); padding: 1.4rem; }
			.trust-item h3 { margin: 0 0 0.5rem; font-size: 1.05rem; }
			.trust-item p { color: var(--muted); font-size: 0.9rem; margin: 0 0 0.5rem; }

			/* ── Dev ── */
			.dev-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 1.5rem; align-items: center; margin-bottom: 1.2rem; }
			.dev-links { display: grid; gap: 0.6rem; }
			.dev-links a { font-size: 0.95rem; }
			.acc { max-width: 760px; margin: 0 auto; background: var(--panel); border: 1px solid var(--panel-border); border-radius: 12px; overflow: hidden; }
			.acc summary { cursor: pointer; padding: 0.9rem 1.2rem; font-weight: 600; list-style: none; display: flex; align-items: center; justify-content: space-between; }
			.acc summary::-webkit-details-marker { display: none; }
			.acc summary::after { content: '+'; color: var(--muted); font-size: 1.2rem; }
			.acc[open] summary::after { content: '−'; }
			.acc-body { padding: 0 1.2rem 1.1rem; color: var(--muted); font-size: 0.94rem; }
			.acc-body .mini { background: none; border: none; padding: 0; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); margin: 0.9rem 0 0.3rem; }

			.code {
				position: relative; background: #0a0a0f; border: 1px solid var(--panel-border);
				border-radius: 10px; padding: 0.8rem 3.5rem 0.8rem 0.9rem; margin: 0.4rem 0; overflow-x: auto;
			}
			.code code { color: #d8e8ff; white-space: pre-wrap; word-break: break-all; }
			.copy {
				position: absolute; top: 0.55rem; right: 0.55rem; padding: 0.25rem 0.6rem;
				font-size: 0.75rem; border-radius: 7px; cursor: pointer;
				background: var(--panel); border: 1px solid var(--panel-border); color: var(--muted);
			}
			.copy:hover { color: var(--text); border-color: var(--cyan); }
			.copy.copied { color: var(--cyan); border-color: var(--cyan); }

			/* ── Footer ── */
			.footer { border-top: 1px solid var(--panel-border); margin-top: 2rem; }
			.footer-inner {
				max-width: var(--maxw); margin: 0 auto; padding: 2rem 1.5rem;
				display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap;
			}
			.footer-brand { display: flex; align-items: center; gap: 0.8rem; }
			.footer-brand img { cursor: pointer; }
			.footer-brand strong { font-size: 0.98rem; }
			.footer-brand p { margin: 0.1rem 0 0; color: var(--muted); font-size: 0.85rem; max-width: 42ch; }
			.footer-links { display: flex; gap: 1.3rem; font-size: 0.9rem; }
			.footer-links a { color: var(--muted); }
			.footer-links a:hover { color: var(--text); text-decoration: none; }

			/* ── Reveal ── */
			/* Stagger groups */
			.reveal-group > *:nth-child(2) { transition-delay: var(--stagger); }
			.reveal-group > *:nth-child(3) { transition-delay: calc(var(--stagger) * 2); }
			.reveal-group > *:nth-child(4) { transition-delay: calc(var(--stagger) * 3); }
			.reveal-group > *:nth-child(5) { transition-delay: calc(var(--stagger) * 4); }
			.reveal-group > *:nth-child(6) { transition-delay: calc(var(--stagger) * 5); }
			/* Demo panel choreography (default = final; JS arms then plays) */
			.demo-card .bar { transform-origin: left; }
			.demo-card.js-anim .demo-row { opacity: 0; transform: translateY(10px); }
			.demo-card.js-anim .bar { transform: scaleX(0); }
			.demo-card.js-anim.play .demo-row { opacity: 1; transform: none; transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out); }
			.demo-card.js-anim.play .demo-row:nth-child(2) { transition-delay: 0.06s; }
			.demo-card.js-anim.play .demo-row:nth-child(3) { transition-delay: 0.14s; }
			.demo-card.js-anim.play .demo-row:nth-child(4) { transition-delay: 0.22s; }
			.demo-card.js-anim.play .demo-row:nth-child(5) { transition-delay: 0.30s; }
			.demo-card.js-anim.play .bar { transform: scaleX(1); transition: transform 0.7s var(--ease-out) 0.32s; }
			.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
			.reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.6s ease, transform 0.6s ease; }
			.reveal.shown { opacity: 1; transform: none; }

			/* ── Responsive ── */
			@media (max-width: 940px) {
				.hero { grid-template-columns: 1fr; gap: 2.5rem; }
				.hero-stage { margin-top: 0.5rem; }
				.chip-float--tl, .chip-float--bl { left: 2%; }
				.chip-float--tr, .chip-float--br { right: 2%; }
				.spot, .senpai, .demo-card, .dev-grid { grid-template-columns: 1fr; gap: 1.5rem; }
				.spot--rev .spot-copy, .spot--rev .spot-shot { order: 0; }
				.demo-side { border-left: none; border-top: 1px solid var(--panel-border); padding-left: 0; padding-top: 1.2rem; }
			}
			@media (max-width: 720px) {
				.story-grid, .mini-grid, .trust-grid, .cards-grid { grid-template-columns: 1fr; }
				.btn { min-width: 0; flex: 1 1 100%; }
				.demo-row { grid-template-columns: 1.6fr 1.2fr; row-gap: 0.3rem; }
				.demo-row span[role="columnheader"]:nth-child(3), .demo-row span[role="columnheader"]:nth-child(4),
				.demo-row span[role="cell"]:nth-child(3), .demo-row span[role="cell"]:nth-child(4) { display: none; }
				.chip-float { display: none; }
			}
			@media (prefers-reduced-motion: reduce) {
				html { scroll-behavior: auto; }
				.reveal { transition: none; }
				.btn:hover, .card:hover { transform: none; }
				.chip-float { animation: none; }
				.spot-region { transition: none; animation: none; }
				.senpai-orb img { animation: none; }
				.reveal-group > * { transition-delay: 0ms; }
			}
		</style>
	</body>
</html>
