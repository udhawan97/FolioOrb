		<script define:vars={{ API: `https://api.github.com/repos/${REPO}/releases/latest`, TAGS_API: `https://api.github.com/repos/${REPO}/git/refs/tags` }}>
			// ── OS-aware CTA ──────────────────────────────────────────────────
			function detectOS() {
				const p = (navigator.userAgentData?.platform || navigator.platform || navigator.userAgent || '').toLowerCase();
				if (p.includes('mac')) return 'mac';
				if (p.includes('win')) return 'win';
				return 'other';
			}
			const os = detectOS();
			if (os !== 'other') {
				document.querySelectorAll('.btn[data-os]').forEach((b) => {
					if (b.getAttribute('data-os') === os) b.classList.add('is-preferred');
					else b.classList.add('is-secondary');
				});
			}

			// ── Live release metadata (with graceful fallback) ───────────────
			function fmtBytes(n) {
				if (!n) return '';
				const mb = n / (1024 * 1024);
				return mb >= 1 ? `${mb.toFixed(0)} MB` : `${(n / 1024).toFixed(0)} KB`;
			}
			function fmtDate(iso) {
				try { return new Date(iso).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }); }
				catch { return ''; }
			}
			function pickAsset(assets, ext) {
				return assets.find((a) => a.name.toLowerCase().endsWith(ext));
			}
			function applyRelease(data) {
				if (!data || !data.assets) return;
				const dmg = pickAsset(data.assets, '.dmg');
				const exe = pickAsset(data.assets, '.exe');
				const setBtn = (id, assetObj) => {
					const btn = document.getElementById(id);
					if (!btn || !assetObj) return;
					btn.href = assetObj.browser_download_url;
					const meta = btn.querySelector('[data-role="meta"]');
					if (meta) meta.textContent = `${data.tag_name} · ${fmtBytes(assetObj.size)}`;
				};
				setBtn('dl-mac', dmg);
				setBtn('dl-win', exe);
				document.querySelectorAll('[data-role="card-dl"]').forEach((el) => {
					const a = el.getAttribute('data-os') === 'mac' ? dmg : exe;
					if (a) el.href = a.browser_download_url;
				});

				const strip = document.getElementById('release-strip');
				if (strip) {
					const set = (role, text) => { const el = strip.querySelector(`[data-role="${role}"]`); if (el) el.textContent = text; };
					set('version', data.tag_name || '—');
					set('date', fmtDate(data.published_at));
					const link = strip.querySelector('[data-role="release-link"]');
					if (link && data.html_url) link.href = data.html_url;
					strip.hidden = false;
					// Best-effort commit SHA from the tag ref (non-blocking).
					// Lightweight tags point straight at a commit (object.type === "commit").
					// Annotated tags point at a tag object whose own .sha is NOT a commit — it
					// has to be dereferenced one level via object.url to reach the commit.
					if (data.tag_name) {
						fetch(`${TAGS_API}/${data.tag_name}`, { headers: { Accept: 'application/vnd.github+json' } })
							.then((r) => (r.ok ? r.json() : null))
							.then((ref) => {
								if (!ref?.object) return null;
								if (ref.object.type === 'commit') return ref.object.sha;
								return fetch(ref.object.url, { headers: { Accept: 'application/vnd.github+json' } })
									.then((r) => (r.ok ? r.json() : null))
									.then((tagObj) => tagObj?.object?.sha || null);
							})
							.then((sha) => {
								if (sha) {
									const el = strip.querySelector('[data-role="sha"]');
									if (el) { el.textContent = sha.slice(0, 7); el.hidden = false; }
								}
							})
							.catch(() => {});
					}
				}
			}
			async function loadRelease() {
				const key = 'fs-release-latest';
				try {
					const cached = sessionStorage.getItem(key);
					if (cached) { applyRelease(JSON.parse(cached)); return; }
					const r = await fetch(API, { headers: { Accept: 'application/vnd.github+json' } });
					if (!r.ok) return; // keep static fallback links
					const data = await r.json();
					sessionStorage.setItem(key, JSON.stringify(data));
					applyRelease(data);
				} catch { /* offline / rate-limited → static fallbacks remain */ }
			}
			loadRelease();

			// ── Copy buttons ─────────────────────────────────────────────────
			document.querySelectorAll('.code .copy').forEach((btn) => {
				btn.addEventListener('click', async () => {
					const text = btn.closest('.code')?.getAttribute('data-copy') || '';
					try {
						await navigator.clipboard.writeText(text);
						const prev = btn.textContent;
						btn.textContent = '✓ Copied';
						btn.classList.add('copied');
						setTimeout(() => { btn.textContent = prev; btn.classList.remove('copied'); }, 1400);
					} catch { /* clipboard blocked — no-op */ }
				});
			});

			// ── Reduced-motion gate ──────────────────────────────────────────
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			// ── Scroll reveal ────────────────────────────────────────────────
			if (reduce || !('IntersectionObserver' in window)) {
				document.querySelectorAll('.reveal').forEach((el) => el.classList.add('shown'));
			} else {
				const io = new IntersectionObserver((entries) => {
					entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('shown'); io.unobserve(e.target); } });
				}, { threshold: 0.12 });
				document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
			}

			// ── Hero: floating-chip parallax (subtle, pointer-fine only) ─────
			const stage = document.getElementById('hero-stage');
			if (stage && !reduce && window.matchMedia('(pointer:fine)').matches) {
				const chips = stage.querySelectorAll('.chip-float');
				stage.addEventListener('pointermove', (e) => {
					const r = stage.getBoundingClientRect();
					const dx = (e.clientX - r.left) / r.width - 0.5;
					const dy = (e.clientY - r.top) / r.height - 0.5;
					chips.forEach((c) => {
						const d = parseFloat(c.getAttribute('data-depth') || '0');
						c.style.transform = `translate(${dx * d}px, ${dy * d}px)`;
					});
				});
				stage.addEventListener('pointerleave', () => { chips.forEach((c) => { c.style.transform = ''; }); });
			}

			// ── Hero: region-fitting guided tour (morphs between hotspots) ───
			const region = document.getElementById('spot-region');
			const regionTip = document.getElementById('spot-region-tip');
			const tourLive = document.getElementById('tour-live');
			const heroWindow = document.getElementById('hero-window');
			if (region && regionTip && heroWindow) {
				// x/y/w/h as % of the screenshot; tuned to the demo dashboard regions.
				const hotspots = [
					{ x: 2.5, y: 39, w: 24, h: 20, label: 'Live value & today’s P&L' },
					{ x: 50, y: 39, w: 22, h: 16, label: 'What moved, in dollars' },
					{ x: 2, y: 61, w: 40, h: 34, label: 'Look-through sector exposure' },
					{ x: 43, y: 61, w: 55, h: 34, label: 'Today’s impact, in plain English' },
					{ x: 74, y: 80, w: 22, h: 16, label: 'Senpai reads the room' },
				];
				let hi = 0, timer = null, paused = false;
				const place = (h) => {
					region.style.left = h.x + '%'; region.style.top = h.y + '%';
					region.style.width = h.w + '%'; region.style.height = h.h + '%';
					regionTip.textContent = h.label;
					if (tourLive) tourLive.textContent = h.label;
				};
				place(hotspots[0]);
				if (!reduce) {
					region.classList.add('is-live');
					const step = () => { if (!paused) { hi = (hi + 1) % hotspots.length; place(hotspots[hi]); } };
					const start = () => { if (!timer) timer = setInterval(step, 3200); };
					const stop = () => { clearInterval(timer); timer = null; };
					heroWindow.addEventListener('pointerenter', () => { paused = true; });
					heroWindow.addEventListener('pointerleave', () => { paused = false; });
					if ('IntersectionObserver' in window) {
						new IntersectionObserver((es) => es.forEach((e) => (e.isIntersecting ? start() : stop())), { threshold: 0.2 }).observe(heroWindow);
					} else { start(); }
				}
			}

			// ── Demo loops + panel choreography: run only while on-screen ────
			if ('IntersectionObserver' in window) {
				const activeIO = new IntersectionObserver((entries) => {
					entries.forEach((e) => {
						const el = e.target;
						if (el.tagName === 'VIDEO') {
							if (reduce) return;               // posters only under reduced motion
							if (e.isIntersecting) el.play().catch(() => {}); else el.pause();
						} else if (e.isIntersecting) {
							el.classList.add('play');         // demo panel: play once, keep final state
						}
					});
				}, { threshold: 0.35 });
				document.querySelectorAll('.demo-loop, #demo-card').forEach((el) => activeIO.observe(el));
			}
			// JS-armed animation: without JS the panel/bars render in their final state.
			const demoCard = document.getElementById('demo-card');
			if (demoCard && !reduce) demoCard.classList.add('js-anim');
			if (reduce) document.querySelectorAll('.demo-loop').forEach((v) => v.setAttribute('controls', ''));

			// ── Senpai: breathing card that types its read on reveal ────────
			const senpaiCard = document.getElementById('senpai-card');
			const senpaiLine = document.getElementById('senpai-line');
			if (senpaiCard && senpaiLine) {
				const lines = [
					senpaiLine.textContent.trim(),
					'VOO did the heavy lifting again. SCHD quietly paid you to wait.',
					'Beta 0.85 — you’ll lag the rip and dodge the worst of the dip.',
					'MSFT leads the book. Concentration’s fine — just know it’s there.',
					'Technology is 17% of your look-through exposure. Eyes open.',
				];
				let idx = 0, typing = null;
				const type = (text) => {
					clearTimeout(typing);
					if (reduce) { senpaiLine.textContent = text; return; }
					senpaiLine.classList.add('is-typing');
					let i = 0;
					const tick = () => {
						senpaiLine.textContent = text.slice(0, i++);
						if (i <= text.length) typing = setTimeout(tick, 22);
						else senpaiLine.classList.remove('is-typing');
					};
					tick();
				};
				let armed = false;
				const fire = () => { if (!armed) { armed = true; type(lines[0]); } };
				if ('IntersectionObserver' in window && !reduce) {
					new IntersectionObserver((es, ob) => es.forEach((e) => { if (e.isIntersecting) { fire(); ob.disconnect(); } }), { threshold: 0.5 }).observe(senpaiCard);
				} else { fire(); }
				senpaiCard.addEventListener('click', () => { idx = (idx + 1) % lines.length; type(lines[idx]); });
			}

			// ── Senpai footer easter egg ─────────────────────────────────────
			const quips = [
				'Not financial advice. Very much a dashboard.',
				'Your "diversified" portfolio is four tech stocks in a trench coat.',
				'The line went up. I have theories about why.',
				'I watch your portfolio so you don’t have to stare at it alone.',
				'Green Tuesday? I’ll take partial credit.',
			];
			let qi = 0;
			const egg = document.getElementById('senpai-egg');
			const quip = document.getElementById('senpai-quip');
			egg?.addEventListener('click', () => { qi = (qi + 1) % quips.length; if (quip) quip.textContent = quips[qi]; });
		</script>

