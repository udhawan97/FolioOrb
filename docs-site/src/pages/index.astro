---
/**
 * FolioSenseAI landing / download page.
 *
 * Standalone Astro page (not the Starlight docs layout) that takes over the
 * site root. Built as a "product demo disguised as a landing page": real,
 * retina app screenshots (captured via docs-site/scripts/capture.sh) anchor
 * every section, with CSS-only motion and a tiny bit of vanilla JS.
 *
 * Release metadata is fetched client-side from the GitHub API with static
 * fallbacks, so the download buttons always work even with JS disabled or the
 * API unreachable. No runtime dependencies; keep it fast on GitHub Pages.
 */
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const REPO = 'udhawan97/FolioSenseAI';
const GITHUB = `https://github.com/${REPO}`;
const RELEASES = `${GITHUB}/releases`;
const RELEASES_LATEST = `${RELEASES}/latest`;

const asset = (p) => `${base}/assets/${p}`;
const shot = (p) => `${base}/assets/shots/${p}`;
const demo = (p) => `${base}/assets/demos/${p}`;
const doc = (slug) => `${base}/${slug}/`;

const macCommands = `curl -fsSL ${'https://raw.githubusercontent.com'}/${REPO}/main/scripts/install-mac.sh | bash`;
const winCommands = `irm ${'https://raw.githubusercontent.com'}/${REPO}/main/scripts/install-win.ps1 | iex`;

// Feature spotlights. `verdicts` and `news` are real recorded product loops
// (video + poster, lazy, pause off-screen); `risk` stays a still — it's the
// dense "read me" panel where motion would fight comprehension.
const spotlights = [
  {
    key: 'risk',
    kicker: 'Risk analytics',
    title: 'See the risk behind the return',
    body: 'Risk-vs-return scatter, correlation matrix, concentration, beta, and drawdown — every number explained in a plain-English line beneath it.',
    img: 'risk-analytics-demo.webp',
    alt: 'FolioSenseAI risk analytics: risk-return scatter, correlation matrix, concentration dial, and beta.',
  },
  {
    key: 'verdicts',
    kicker: 'Hold / Add / Trim / Exit',
    title: 'A verdict for every position',
    body: 'Open a holding and its intelligence panel unfolds — rating, trend read, ETF-quality or analyst context, and what moved it today. The table tells you what to do, not just what it is worth.',
    video: 'verdicts',
    alt: 'FolioSenseAI holdings table expanding a position into its full intelligence panel with rating, drivers, and sparklines.',
  },
  {
    key: 'news',
    kicker: 'News themes',
    title: 'The headlines that actually touch your book',
    body: 'Grouped, deduplicated news for everything you hold or watch, populated per position — with optional Claude-written portfolio themes when a key is connected.',
    video: 'news',
    alt: 'FolioSenseAI news feed populating grouped, relevant headlines under each holding in the demo portfolio.',
  },
];

// Small, crisp vector icons (no emoji, no raster) for the icon cards.
const icons = {
  lock: '<path d="M6 10V7a6 6 0 0 1 12 0v3" /><rect x="4" y="10" width="16" height="10" rx="2" /><circle cx="12" cy="15" r="1.4" fill="currentColor" stroke="none"/>',
  spark: '<path d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5 18 18M18 6l-2.5 2.5M8.5 15.5 6 18"/>',
  pulse: '<path d="M3 12h4l2.5-6 4 12 2.5-6H21"/>',
};
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>FolioSenseAI — Your portfolio, finally speaking plain English.</title>
		<meta name="description" content="A local-first portfolio intelligence dashboard for macOS and Windows. Turns holdings, risk, market context, and news into plain-English answers — running entirely on your machine, with Claude as an optional layer." />
		<link rel="icon" type="image/svg+xml" href={asset('folio-orbit-icon.svg')} />
		<meta property="og:title" content="FolioSenseAI" />
		<meta property="og:description" content="Your portfolio, finally speaking plain English. A local-first portfolio intelligence dashboard for macOS and Windows." />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={asset('og-hero.jpg')} />
